# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ── Database ───────────────────────────────────────────────────────────────
# Standard PostgreSQL DSN.  Adjust host/port/dbname as needed.
DATABASE_URL=postgresql://postgres:password@localhost:5432/job_pipeline

# ── SerpAPI ───────────────────────────────────────────────────────────────
SERPAPI_KEY=your_serpapi_key_here

# ── OpenRouter ────────────────────────────────────────────────────────────
# Used for extraction LLM (Step 3), Tier 2 scoring, and optionally Tier 3.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# ── Anthropic (optional) ──────────────────────────────────────────────────
# If set, Tier 3 deep analysis calls the Anthropic API directly instead of
# routing through OpenRouter.  Leave blank to route everything via OpenRouter.
ANTHROPIC_API_KEY=

# ── Model selection ───────────────────────────────────────────────────────
# These are OpenRouter model IDs.  See https://openrouter.ai/models for options.
# Change any of these to swap models without touching code.
#
# Cheap extraction + scoring candidates:
#   google/gemini-flash-1.5
#   deepseek/deepseek-chat
#   moonshotai/kimi-k2
#   meta-llama/llama-3.1-8b-instruct
#
# Deep analysis candidates:
#   anthropic/claude-sonnet-4-5          (via OpenRouter)
#   anthropic/claude-opus-4              (via OpenRouter, higher quality/cost)
EXTRACTION_MODEL=google/gemini-flash-1.5
SCORING_MODEL=google/gemini-flash-1.5
DEEP_ANALYSIS_MODEL=anthropic/claude-sonnet-4-5

# ── Embedding ─────────────────────────────────────────────────────────────
# all-mpnet-base-v2 is downloaded automatically on first run (~420 MB).
# To upgrade, swap to e.g. BAAI/bge-large-en-v1.5 (1024-dim, update EMBEDDING_DIM).
EMBEDDING_MODEL=all-mpnet-base-v2
EMBEDDING_DIM=768
EMBEDDING_MAX_TOKENS=384

# ── Pipeline tuning ───────────────────────────────────────────────────────
DEDUP_FUZZY_THRESHOLD=85       # token_sort_ratio threshold (0-100)
TIER1_CANDIDATES=100           # jobs fetched from pgvector for Tier 2
TIER2_TOP_N=15                 # jobs passed to Tier 3 after scoring
TIER2_CONCURRENCY=10           # concurrent async calls in Tier 2
DAILY_MAX_PAGES=2              # SerpAPI pages per query in daily mode (10 results/page)
BACKFILL_MAX_PAGES=10          # SerpAPI pages per query in backfill mode
JOB_EXPIRY_DAYS=30             # days after date_listed before status → expired
